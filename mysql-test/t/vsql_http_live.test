--echo # vsql_http — live HTTPS test against villagesql.com/robots.txt
--echo # Requires network access. Skip with: --skip-test=vsql_http_live

INSTALL EXTENSION vsql_http;

--echo # GET robots.txt: status 200
SELECT JSON_VALUE(CONVERT(vsql_http.http_get('https://villagesql.com/robots.txt') USING utf8mb4), '$.status');

--echo # content_type is non-null
SELECT JSON_VALUE(CONVERT(vsql_http.http_get('https://villagesql.com/robots.txt') USING utf8mb4), '$.content_type') IS NOT NULL;

--echo # response content is non-null
SELECT JSON_VALUE(CONVERT(vsql_http.http_get('https://villagesql.com/robots.txt') USING utf8mb4), '$.content') IS NOT NULL;

--echo # headers array is non-empty
SELECT JSON_LENGTH(CONVERT(vsql_http.http_get('https://villagesql.com/robots.txt') USING utf8mb4), '$.headers') > 0;

UNINSTALL EXTENSION vsql_http;
